DISCORD_ENABLED=true
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_channel_id

SLACK_ENABLED=false
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=

# Comma-separated RSS feed URLs
NEWS_FEEDS=https://www3.nhk.or.jp/rss/news/cat0.xml,https://news.yahoo.co.jp/rss/topics/top-picks.xml

# Daily at 08:00 (Asia/Tokyo)
CRON_SCHEDULE=0 8 * * *
TZ=Asia/Tokyo
MAX_NEWS_ITEMS=12
RUN_ON_START=true

# Optional: if set, use AI summary. If empty, fallback summary is used.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
SUMMARY_MODEL=gpt-4.1-mini

# Chat settings
CHAT_ENABLED=true
CHAT_PREFIX=news
# Optional: if set, only this channel will receive chat replies
CHAT_CHANNEL_ID=

SLACK_CHAT_ENABLED=true
SLACK_CHAT_PREFIX=news
# Optional: if set, only this channel will receive chat replies
SLACK_CHAT_CHANNEL_ID=

SLACK_CAMERA_ENABLED=true
# Optional: if set, only this Slack channel can trigger camera capture
SLACK_CAMERA_CHANNEL_ID=
CAMERA_CAPTURE_TIME_MS=1200
CAMERA_OUTPUT_DIR=output/camera
