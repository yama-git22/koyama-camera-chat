DISCORD_ENABLED=true
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_channel_id

SLACK_ENABLED=false
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=

# Comma-separated RSS feed URLs
NEWS_FEEDS=https://www3.nhk.or.jp/rss/news/cat0.xml,https://news.yahoo.co.jp/rss/topics/top-picks.xml

# Daily at 08:00 (Asia/Tokyo)
CRON_SCHEDULE=0 8 * * *
TZ=Asia/Tokyo
MAX_NEWS_ITEMS=12
RUN_ON_START=true

# Optional: if set, use AI summary. If empty, fallback summary is used.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
SUMMARY_MODEL=gpt-4.1-mini

# Chat settings
CHAT_ENABLED=true
CHAT_PREFIX=news
# Optional: if set, only this channel will receive chat replies
CHAT_CHANNEL_ID=

SLACK_CHAT_ENABLED=true
SLACK_CHAT_PREFIX=news
# Optional: if set, only this channel will receive chat replies
SLACK_CHAT_CHANNEL_ID=

SLACK_CAMERA_ENABLED=true
# Optional: if set, only this Slack channel can trigger camera capture
SLACK_CAMERA_CHANNEL_ID=
CAMERA_CAPTURE_TIME_MS=1200
CAMERA_OUTPUT_DIR=output/camera

# ---- network paper bot (arXiv -> Ollama -> Slack) ----
PAPER_SEARCH_QUERY=cat:cs.NI
PAPER_CRON_SCHEDULE=0 9 * * *
PAPER_RUN_ON_START=false
PAPER_FETCH_LIMIT=25
PAPER_MAX_POSTS=5
PAPER_LOOKBACK_HOURS=48
PAPER_POST_EMPTY_UPDATE=true
PAPER_STATE_FILE=output/network-paper-bot-state.json

ARXIV_API_URL=https://export.arxiv.org/api/query
# Recommended: replace with your lab/admin email
ARXIV_USER_AGENT=network-paper-bot/1.0 (mailto:your_email@example.com)
ARXIV_MAX_RETRIES=3
ARXIV_RETRY_DELAY_MS=20000
ARXIV_TIMEOUT_MS=60000

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_KEEP_ALIVE=10m
OLLAMA_TIMEOUT_MS=120000

# ---- note article generation + X auto posting ----
# Cron schedule for note/x automation (daily at 09:00 JST)
NOTE_X_CRON_SCHEDULE=0 9 * * *
NOTE_X_RUN_ON_START=true

# Input topics (comma-separated)
NOTE_TOPICS=AIの最新活用,個人開発の学び,自動化で時短した実例

# Optional reference feeds for article generation (comma-separated)
NOTE_REFERENCE_FEEDS=https://www3.nhk.or.jp/rss/news/cat0.xml,https://news.yahoo.co.jp/rss/topics/top-picks.xml
NOTE_REFERENCE_MAX_ITEMS=6
NOTE_MIN_INTERVAL_HOURS=20
NOTE_MODEL=gpt-4.1-mini
NOTE_OUTPUT_DIR=output

# Optional command to publish a markdown draft to note.
# Placeholders: {file} {title} {slug}
# If this command prints a URL to stdout/stderr, that URL will be included in the tweet.
NOTE_PUBLISH_COMMAND=

# Optional fallback URL when NOTE_PUBLISH_COMMAND is not set or does not return a URL.
NOTE_FALLBACK_URL=

# X posting toggle
X_ENABLED=true
X_USERNAME=
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
